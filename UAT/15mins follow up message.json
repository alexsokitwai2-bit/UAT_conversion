    {
      "parameters": {
        "jsCode": "const inputData = $input.first().json; // 獲取第一個輸入對象\nconst data = inputData.data; // 獲取嵌套的資料陣列\n//const phoneList = $('EIHL Sales Phone Number List').first().json; // 定义需要排除的手机号码列表\n\n// 将手机号码列表转换为一个 Set，以便快速查找\n//const phoneSet = new Set(phoneList.phone);\n\n// 获取当前时间\nconst currentTime = new Date();\n\n// 过滤记录：排除在手机号码列表中的记录以及15分钟以内的记录\nconst filteredData = data.filter(item => {\n    const timestamp = new Date(item.timestamp);\n    const differenceInMinutes = (currentTime - timestamp) / 1000 / 60; // 转换为分钟\n\n    // 仅保留不在手机号码列表中且距当前时间超过15分钟的记录\n    return differenceInMinutes > 15;\n});\n\n// 创建输出结果\nreturn filteredData.map(item => {\n    const localDate = new Date(item.timestamp);\n    localDate.setHours(localDate.getHours() + 8);  // 转换为 GMT+8\n\n    return {\n        json: {\n            timestamp: `${localDate.toISOString().replace(\"Z\", \"\")}`, // 以 ISO 格式输出并添加时区标识\n            mobile_num: item.mobile_num,\n            message: item.message,\n            source: item.source,\n            to: item.to,\n            type: item.type\n        }\n    };\n});"
      },
