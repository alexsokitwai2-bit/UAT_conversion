      "parameters": {
        "jsCode": "function addMatchingRecords(data, contacts) {\n    // 遍历 data 数组\n    data.forEach(item => {\n        // 针对每个 data 项的 mobile_num 进行配对\n        const matchingContact = contacts.find(contact => contact.Mobile === item.mobile_num);\n        \n        // 如果找到匹配的联系人，添加到 data 项\n        if (matchingContact) {\n            // 附加联系人信息到 data 项中\n            item.contactId = matchingContact.id; // 添加 contact ID\n            item.Talke_Lang = matchingContact.Talke_Lang; // 将讲语言添加\n        }\n    });\n\n    return data; // 返回修改后的 data 数组\n}\n\n// 示例数据\nconst dataJson = $('Aggregate1').first().json.dataJSON;\n\nconst contactJson = $('Aggregate2').first().json.contactJSON;\n\n// 调用函数\nconst updatedData = addMatchingRecords(dataJson, contactJson);\n\n// 返回结果\nreturn updatedData;"
      },
