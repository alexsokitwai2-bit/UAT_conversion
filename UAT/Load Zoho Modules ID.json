    {
      "parameters": {
        "jsCode": "// 取得第一個輸入 item 的 json（你原本用 $input.first().json）\nconst input = $input.first().json;\n\n// data 可能在 input.data，或如果你是把 data 用 expression 傳入 items[0].json.data，則也是這裡\nconst dataArray = input.data || input; // 若 input 本身就是 data 陣列，容錯處理\n\nif (!Array.isArray(dataArray)) {\n  // 若沒有陣列，回傳空陣列避免流程中斷\n  return [];\n}\n\nconst output = dataArray.map(rec => ({\n  json: {\n    id: rec.id || null,\n    Campaign_Name: rec.Campaign_Name || rec.Camiaign_Name || null,\n  }\n}));\n\nreturn output;"
      },
