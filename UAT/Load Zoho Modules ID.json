    {
      "parameters": {
        "jsCode": "// 取得第一個輸入 item 的 json\nconst input = $input.first().json;\n\n// 支援兩種情況：1) input.data 為陣列（整個物件傳入） 2) input 本身就是 data 陣列\nconst dataArray = Array.isArray(input.data) ? input.data : (Array.isArray(input) ? input : (Array.isArray(input) ? input : input.data || input));\n\nif (!Array.isArray(dataArray)) {\n  // 若非陣列則回傳空陣列，避免流程中斷\n  return [];\n}\n\nconst output = dataArray.map(rec => {\n  return {\n    json: {\n      Name: rec.Name || null,\n      id: rec.id || null,\n      TierLabel_name: (rec.TierLabel && rec.TierLabel.name) ? rec.TierLabel.name : null,\n    }\n  };\n});\n\nreturn output;"
      },
