    {
      "parameters": {
        "jsCode": "const inputData = $input.first().json; // 获取第一个输入对象\nconst data = inputData.data; // 获取嵌套的数据数组\nconst currentDate = new Date(); // 获取当前日期\ncurrentDate.setHours(0, 0, 0, 0); // 清除时间部分，仅保留日期\n\nconsole.log(\"当前日期:\", currentDate);\n\nconst filteredRecords = data.filter(item => {\n    // 检查 field3 是否存在且不为 null 或空\n    if (item.field3 && item.field3.trim() !== '') {\n        const field3Date = new Date(item.field3); // 将 field3 转换为日期对象\n\n        // 检查 field3 是否为有效日期\n        if (!isNaN(field3Date)) {\n            console.log(\"字段3日期:\", field3Date);\n\n            // 计算当前月份和 field3 的月份差\n            const monthDifference = (field3Date.getFullYear() - currentDate.getFullYear()) * 12 + \n                                    (field3Date.getMonth() - currentDate.getMonth());\n\n            console.log(\"月份差:\", monthDifference);\n\n            // 检查是否为一个月后\n            if (monthDifference === 1 && field3Date.getDate() === currentDate.getDate()) {\n                console.log(\"找到符合条件的记录:\", item.Full_Name);\n                return true; // 包含该项\n            }\n        } else {\n            console.warn(`无效日期格式: ${item.field3}`); // 日志警告\n        }\n    } else {\n        console.warn(`field3 为空或为 null: ${item.Full_Name}`); // 日志警告\n    }\n    return false; // 跳过无效项\n});\n\n// 返回符合条件的记录\nreturn filteredRecords.map(item => ({ json: item }));"
      },
