    {
      "parameters": {
        "jsCode": "const inputData = $input.first().json; // Access the first input object\nconst data = inputData.data; // Get the nested data array\nconst currentTimeGMT = new Date().toISOString();\n\nconst filteredHBD = data.filter(item => {\n    // Check if Date_of_Birth exists and is not null/empty\n    if (item.Date_of_Birth && item.Date_of_Birth.trim() !== '') {\n        // Extract MM-DD using regex: match YYYY-MM-DD\n        const match = item.Date_of_Birth.match(/(\\d{4})-(\\d{2})-(\\d{2})/);\n        if (match) {\n            const monthDay = `${match[2]}-${match[3]}`; // \"01-01\"\n            // Add the extracted MM-DD to the item\n            item.Birth_Month_Day = monthDay;\n            return true; // Include this item\n        }\n    }\n    return false; // Skip invalid items\n});\n\n// Return with the enhanced data\nreturn filteredHBD.map(item => ({ json: item }));"
      },
