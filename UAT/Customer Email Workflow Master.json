      "parameters": {
        "jsCode": "const data = $input.first().json.data; // 假設您的資料已經在這裡\n\n// 獲取今天的 MM-DD\nconst today = new Date();\nconst todayMonth = String(today.getMonth() + 1).padStart(2, '0'); // 月份從 0 開始，所以 +1\nconst todayDay = String(today.getDate()).padStart(2, '0');\nconst todayMMDD = `${todayMonth}-${todayDay}`; // 例如 \"10-31\"\n\nconsole.log(`今天日期 (MM-DD): ${todayMMDD}`);\n\n// 過濾出今天生日的紀錄\nconst birthdayToday = data.filter(record => {\n    return record.Birth_Month_Day === todayMMDD;\n});\n\n// 返回結果\nif (birthdayToday.length > 0) {\n    return birthdayToday.map(record => ({ json: record }));\n} else {\n    // 如果沒有今天生日的，返回空陣列或訊息\n    return null;\n}"
