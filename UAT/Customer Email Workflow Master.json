      "parameters": {
        "jsCode": "const inputData = $input.first().json; // 獲取第一個輸入對象\nconst data = inputData.data[0].data; // 獲取嵌套的資料陣列\nconst currentDate = new Date(); // 獲取當前日期\ncurrentDate.setHours(0, 0, 0, 0); // 清除時間部分，僅保留日期\n\nconst filteredFestivals = data.filter(item => {\n    // 將節日日期轉換為 Date 對象\n    const festivalDate = new Date(item.festival_date);\n    festivalDate.setHours(0, 0, 0, 0); // 清除時間部分，僅保留日期\n\n    // 檢查是否等於今天的日期\n    return festivalDate.getTime() === currentDate.getTime();\n});\n\n// 返回符合條件的紀錄\nreturn filteredFestivals.map(item => ({ json: item }));"
