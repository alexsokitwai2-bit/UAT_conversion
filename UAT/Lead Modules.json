      "parameters": {
        "jsCode": "function findMatchingRecord() {\n    // 假设 contactData 就是您提供的 mobile JSON 数据\n    const contactData = $input.first().json.data;\n\n    // 假设 webhookData 就是您提供的 webhook 的数据\n    const webhookData = $('Standard Input').first().json;\n\n    const results = [];\n    \n    // 获取 waId\n    const waId = webhookData.mobile;\n\n    // 查找匹配的记录\n        contactData.forEach(contact => {\n            if (contact.Mobile === waId) {\n                results.push(contact);\n            }\n        });\n\n    return results.length > 0 ? results : []; // 返回匹配的记录或空数组\n}\n\n// 调用函数并返回结果\nreturn findMatchingRecord();"
      },
