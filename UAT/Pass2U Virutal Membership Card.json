    {
      "parameters": {
        "jsCode": "const data = $input.all(); // 获取所有输入数据\n\n// 确保 data[0] 存在再进行筛选\nif (data.length && data[0].json.data) {\n    // 从查询参数中获取 ID\n    const idQuery = $('Webhook').first().json.query.id.trim();\n\n    let ids; // 用于存储 ID 数组\n\n    // 检查 ID 字符串是否包含逗号\n    if (idQuery.includes(',')) {\n        // 如果包含逗号，拆分成数组\n        ids = idQuery.split(',').map(id => id.trim());\n    } else {\n        // 如果不包含逗号，直接将 ID 放入数组\n        ids = [idQuery];\n    }\n\n    // 筛选出 ID 为触发的用户，且确保 vcard 不是 'yes'（忽略大小写）\n    const filteredData = data[0].json.data.filter(item => \n        ids.includes(item.id) \n      //&& (item.vcard === null || item.vcard.toLowerCase() !== 'yes')\n    );\n\n    // 将每个筛选后的结果转换为包含 json 的对象\n    const output = filteredData.map(item => ({ json: item }));\n\n    // 返回结果\n    if (output.length > 0) {\n        return output; // 如果有结果，返回过滤后的数据\n    } else {\n        return [{ json: {} }]; // 如果没有数据，返回空对象\n    }\n} else {\n    // 如果没有找到数据，返回一个空数组\n    return [{ json: {} }]; // 返回一个空对象\n}"
      },
