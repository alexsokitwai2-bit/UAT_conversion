    {
      "parameters": {
        "jsCode": "const now = new Date();\n\n// 獲取 GMT+8 時區的時間\nconst options = { timeZone: 'Asia/Hong_Kong', hour12: false };\nconst formatter = new Intl.DateTimeFormat('en-US', options);\n\n// 獲取 GMT+8 時間的各個組件\nconst localDate = new Date(now.toLocaleString(\"en-US\", { timeZone: \"Asia/Hong_Kong\" }));\n\nlocalDate.setHours(localDate.getHours());\n\n// 格式化為 yyyy-MM-dd hh:mm:ss\nconst year = localDate.getFullYear();\nconst month = String(localDate.getMonth() + 1).padStart(2, '0'); // 月份從 0 開始\nconst day = String(localDate.getDate()).padStart(2, '0');\nconst hours = String(localDate.getHours()).padStart(2, '0');\nconst minutes = String(localDate.getMinutes()).padStart(2, '0');\nconst seconds = String(localDate.getSeconds()).padStart(2, '0');\n\nconst currentDateTime = `${year}-${month}-${day}T${hours}:${minutes}:${seconds}`;\n\nreturn [{ json: { currentDateTime } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -64,
        1120
      ],
      "id": "efa1f80b-9e9a-4e42-ac68-499164653aa9",
      "name": "Now()"
    },
    {
      "parameters": {
        "jsCode": "const leads = $('Aggregate2').first().json.data || [];  // 如果 data 是 undefined，则赋值为一个空数组\nconst name = $('Get contact ID by Mobile').first().json.Full_Name; \n\n// 过滤出名称匹配且 Lead_Status 为 \"Completed\" 的潜在客户\nconst filteredLeads = leads.filter(lead => \n  lead.Full_Name === name && lead.Lead_Status !== \"Completed\"\n);\n\n// 返回符合条件的潜在客户\nreturn filteredLeads.map(lead => ({ json: lead }));"
      },
