    {
      "parameters": {
        "jsCode": "const leads = $input.first().json.data || [];  // 如果 data 是 undefined，则赋值为一个空数组\n\nconst firstMatch = leads.find(lead => {\n  // 检查 lead 是否存在并且是对象\n  if (lead && typeof lead === 'object') {\n    // 检查 Lead_Status 是否不为 \"Completed\"\n    if (lead.Lead_Status !== \"Completed\") {\n      // 检查 PIC_Mobile 和 PIC 是否有效\n      const pic_mobile = (lead.PIC_Mobile !== null && lead.PIC_Mobile !== '')\n        ? lead.PIC_Mobile\n        : (lead.PIC !== null ? lead.PIC : null);\n      \n      // 只有当 pic_mobile 不为 null 时才符合条件\n      return pic_mobile !== null;\n    }\n  }\n  return false; // 如果 lead 不符合条件，返回 false\n});\n\n// 返回符合条件的第一个匹配项，如果没有找到则返回 null\nif (firstMatch) {\n  return {\n    Full_Name: firstMatch.Full_Name,\n    PIC: (firstMatch.PIC_Mobile !== null && firstMatch.PIC_Mobile !== '') \n         ? firstMatch.PIC_Mobile \n         : firstMatch.PIC,\n    PIC_Name: firstMatch.PIC\n  };\n}\n\n// 如果没有找到匹配项，返回 null\nreturn null;"
      },
